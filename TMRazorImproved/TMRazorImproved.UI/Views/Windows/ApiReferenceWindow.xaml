<ui:FluentWindow x:Class="TMRazorImproved.UI.Views.Windows.ApiReferenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="API Reference — TMRazor Improved"
        Height="660" Width="940" MinHeight="420" MinWidth="660"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar area -->
            <RowDefinition Height="Auto"/>   <!-- Search bar -->
            <RowDefinition Height="*"/>      <!-- Main content -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER / TITLE BAR ===== -->
        <Border Grid.Row="0" Padding="16,12,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:TextBlock Text="📖" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ui:TextBlock Text="API Reference" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ui:TextBlock x:Name="StatusText"
                                  Appearance="Secondary" FontSize="11" FontStyle="Italic"
                                  VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <ui:Button Grid.Column="1" x:Name="ExportButton"
                           Content="Export Markdown"
                           Icon="{ui:SymbolIcon Save24}"
                           Appearance="Secondary"
                           Padding="12,5"
                           FontSize="12"
                           ToolTip="Esporta la documentazione come file Markdown"
                           Click="ExportButton_Click"/>
            </Grid>
        </Border>

        <!-- ===== SEARCH BAR ===== -->
        <Border Grid.Row="1" Padding="16,0,16,8">
            <ui:TextBox x:Name="SearchBox"
                        PlaceholderText="Cerca metodo o API...  (es: Player, UseSkill, WaitForTarget)"
                        Icon="{ui:SymbolIcon Search24}"
                        TextChanged="SearchBox_TextChanged"/>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="2" Margin="16,0,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="150"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: TreeView -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource ControlBorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <TreeView x:Name="ApiTree"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="2"
                          SelectedItemChanged="ApiTree_SelectedItemChanged"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Border>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource ControlBorderColorBrush}"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE"/>

            <!-- RIGHT: Detail panel -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource ControlBorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel>

                        <!-- Placeholder when nothing selected -->
                        <StackPanel x:Name="PlaceholderPanel" HorizontalAlignment="Center" Margin="0,60,0,0">
                            <ui:TextBlock Text="📖" FontSize="44" HorizontalAlignment="Center" Opacity="0.25"/>
                            <ui:TextBlock Text="Seleziona un'API o un metodo"
                                          Appearance="Secondary" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <ui:TextBlock Text="oppure cerca con la barra in alto"
                                          Appearance="Secondary" FontSize="11"
                                          HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- API group selected -->
                        <StackPanel x:Name="ApiDetailPanel" Visibility="Collapsed">
                            <ui:TextBlock x:Name="ApiNameText" FontSize="22" FontWeight="Bold" Margin="0,0,0,2"/>
                            <ui:TextBlock x:Name="ApiTypeText" Appearance="Secondary" FontSize="11" Margin="0,0,0,10"/>
                            <ui:TextBlock x:Name="ApiDescText" TextWrapping="Wrap" Margin="0,0,0,16"/>
                            <Separator Margin="0,0,0,12"/>
                            <ui:TextBlock x:Name="ApiMethodCountText" Appearance="Secondary" FontSize="12"/>
                        </StackPanel>

                        <!-- Method selected -->
                        <StackPanel x:Name="MethodDetailPanel" Visibility="Collapsed">

                            <!-- Stub warning -->
                            <Border x:Name="StubWarningBorder" Visibility="Collapsed"
                                    Background="#33F59E0B" BorderBrush="#F59E0B"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="10,7" Margin="0,0,0,14">
                                <ui:TextBlock Text="⚠️  Stub — this method returns a placeholder value."
                                              Foreground="#F59E0B" FontSize="12" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Breadcrumb + name -->
                            <ui:TextBlock x:Name="MethodApiText" Appearance="Secondary" FontSize="12" Margin="0,0,0,1"/>
                            <ui:TextBlock x:Name="MethodNameText" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

                            <!-- Signature (dark code box) -->
                            <Border Background="#1E1E1E" CornerRadius="5" Padding="14,10" Margin="0,0,0,16">
                                <TextBlock x:Name="MethodSignatureText"
                                           FontFamily="Consolas, 'Courier New', monospace"
                                           FontSize="13" Foreground="#4EC9B0"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <!-- Description -->
                            <ui:TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ui:TextBlock x:Name="MethodDescText" TextWrapping="Wrap" Margin="0,0,0,16"/>

                            <!-- Parameters -->
                            <StackPanel x:Name="ParamsPanel" Visibility="Collapsed" Margin="0,0,0,16">
                                <ui:TextBlock Text="Parameters" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="4" Padding="10,6">
                                    <ItemsControl x:Name="ParamsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               FontFamily="Consolas, 'Courier New', monospace"
                                                               FontSize="12" Foreground="#9CDCFE"
                                                               Text="{Binding Display}"
                                                               VerticalAlignment="Top"/>
                                                    <ui:TextBlock Grid.Column="1"
                                                                  Text="{Binding TypeInfo}"
                                                                  Appearance="Secondary" FontSize="11"
                                                                  VerticalAlignment="Top" TextWrapping="Wrap"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>

                            <!-- Return type -->
                            <ui:TextBlock Text="Returns" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border Background="#1A007ACC" CornerRadius="4"
                                    Padding="10,5" HorizontalAlignment="Left">
                                <TextBlock x:Name="ReturnTypeText"
                                           FontFamily="Consolas, 'Courier New', monospace"
                                           FontSize="12" Foreground="#4FC1FF"/>
                            </Border>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="3" Padding="16,8,16,12">
            <Grid>
                <ui:TextBlock x:Name="FooterText"
                               Appearance="Secondary" FontSize="11" VerticalAlignment="Center"/>
                <ui:Button Content="Chiudi"
                           HorizontalAlignment="Right"
                           Appearance="Secondary"
                           Width="90" Padding="0,6"
                           Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
