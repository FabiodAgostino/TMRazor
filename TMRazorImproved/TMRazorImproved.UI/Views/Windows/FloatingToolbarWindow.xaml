<Window x:Class="TMRazorImproved.UI.Views.Windows.FloatingToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:TMRazorImproved.UI.Views.Windows"
        xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels"
        mc:Ignorable="d"
        Title="Toolbar" Height="40" Width="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        d:DataContext="{d:DesignInstance vm:FloatingToolbarViewModel, IsDesignTimeCreatable=False}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="8" 
            Background="{DynamicResource ApplicationBackgroundBrush}" 
            BorderBrush="{DynamicResource ControlElevationBorderBrush}" 
            BorderThickness="1"
            Opacity="0.9"
            Margin="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
            <!-- Hits -->
            <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                <ui:TextBlock Text="HP" FontSize="10" FontWeight="Bold" Foreground="#FF5555"/>
                <Grid Width="60" Height="4">
                    <ProgressBar Value="{Binding HitsPercent, Mode=OneWay}" Minimum="0" Maximum="1" 
                                 Foreground="#FF5555" Background="#33FF5555" BorderThickness="0"/>
                </Grid>
                <ui:TextBlock Text="{Binding Hits}" FontSize="10" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Mana -->
            <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                <ui:TextBlock Text="MP" FontSize="10" FontWeight="Bold" Foreground="#5555FF"/>
                <Grid Width="60" Height="4">
                    <ProgressBar Value="{Binding ManaPercent, Mode=OneWay}" Minimum="0" Maximum="1" 
                                 Foreground="#5555FF" Background="#335555FF" BorderThickness="0"/>
                </Grid>
                <ui:TextBlock Text="{Binding Mana}" FontSize="10" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Stamina -->
            <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                <ui:TextBlock Text="ST" FontSize="10" FontWeight="Bold" Foreground="#55FF55"/>
                <Grid Width="60" Height="4">
                    <ProgressBar Value="{Binding StamPercent, Mode=OneWay}" Minimum="0" Maximum="1" 
                                 Foreground="#55FF55" Background="#3355FF55" BorderThickness="0"/>
                </Grid>
                <ui:TextBlock Text="{Binding Stam}" FontSize="10" HorizontalAlignment="Center"/>
            </StackPanel>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,8" />

            <!-- Weight -->
            <StackPanel Margin="8,0" VerticalAlignment="Center">
                <ui:TextBlock Text="WGT" FontSize="10" FontWeight="Bold" Appearance="Secondary"/>
                <ui:TextBlock Text="{Binding Weight}" FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Tithe -->
            <StackPanel Margin="8,0" VerticalAlignment="Center">
                <ui:TextBlock Text="TTH" FontSize="10" FontWeight="Bold" Appearance="Secondary"/>
                <ui:TextBlock Text="{Binding Tithe}" FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Followers -->
            <StackPanel Margin="8,0" VerticalAlignment="Center">
                <ui:TextBlock Text="FOL" FontSize="10" FontWeight="Bold" Appearance="Secondary"/>
                <ui:TextBlock Text="{Binding Followers}" FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,8" />

            <!-- Dynamic Counters -->
            <ItemsControl ItemsSource="{Binding ActiveCounters}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="8,0" VerticalAlignment="Center">
                            <ui:TextBlock Text="{Binding Abbreviation}" FontSize="10" FontWeight="Bold" Appearance="Secondary" HorizontalAlignment="Center"/>
                            <ui:TextBlock Text="{Binding Count}" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Toolbar Slots (spell/item/command shortcuts) — visibili solo se configurati -->
            <ItemsControl ItemsSource="{Binding Slots}"
                          Visibility="{Binding Slots.Count, Converter={StaticResource IntToVisibilityConverter}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Slot compatto: bordo arancio se in warning, altrimenti neutro -->
                        <Border Width="36" Height="36" Margin="2,0" CornerRadius="4"
                                BorderThickness="1"
                                ToolTip="{Binding Name}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                            <Setter Property="BorderBrush" Value="#F97316"/>
                                            <Setter Property="Background" Value="#1AF97316"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <!-- Nome (abbreviato ai primi 4 caratteri) -->
                                <ui:TextBlock FontSize="9" FontWeight="Bold"
                                             Text="{Binding Name}"
                                             TextTrimming="CharacterEllipsis"
                                             MaxWidth="32"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Center"
                                             TextAlignment="Center"/>
                                <!-- Conteggio item (visibile solo per slot Item) -->
                                <ui:TextBlock FontSize="9"
                                             Text="{Binding Count}"
                                             VerticalAlignment="Bottom"
                                             HorizontalAlignment="Right"
                                             Margin="0,0,2,1"
                                             Foreground="#F97316"
                                             Visibility="{Binding ShowCount, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Close Button (Optional, can be context menu) -->
            <ui:Button Icon="{ui:SymbolIcon Dismiss16}"
                       Padding="4"
                       Margin="8,0,0,0"
                       Appearance="Secondary"
                       Click="CloseButton_Click"
                       ToolTip="Close Toolbar"/>
        </StackPanel>
    </Border>
</Window>
