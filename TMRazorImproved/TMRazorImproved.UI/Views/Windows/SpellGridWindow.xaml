<Window x:Class="TMRazorImproved.UI.Views.Windows.SpellGridWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels"
        mc:Ignorable="d"
        Title="SpellGrid" Height="Auto" Width="Auto"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid Margin="10">
        <ui:Card Padding="4" Background="#CC000000" BorderBrush="#40FFFFFF">
            <ItemsControl ItemsSource="{Binding ActiveSpells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" MaxWidth="400" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2">
                            <ui:Button Command="{Binding DataContext.CastCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                       CommandParameter="{Binding}"
                                       Padding="0"
                                       Width="44" Height="44"
                                       ToolTip="{Binding Name}"
                                       Appearance="Transparent"
                                       BorderThickness="1"
                                       BorderBrush="#20FFFFFF">
                                <Image Source="{Binding SpellId, Converter={StaticResource SpellIconConverter}}" 
                                       Stretch="Uniform" 
                                       Width="40" Height="40"/>
                            </ui:Button>

                            <!-- Cooldown Overlay -->
                            <Border Background="#80000000" 
                                    IsHitTestVisible="False"
                                    Visibility="{Binding IsOnCooldown, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <ProgressBar Value="{Binding RemainingCooldown}" 
                                                 VerticalAlignment="Bottom"
                                                 Height="4"
                                                 Maximum="{Binding CooldownSeconds}"
                                                 Foreground="White"
                                                 Background="Transparent"
                                                 BorderThickness="0"/>
                                    <TextBlock Text="{Binding RemainingCooldown, StringFormat={}{0:F1}}" 
                                               Foreground="White" 
                                               FontSize="10" 
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ui:Card>
    </Grid>
</Window>
