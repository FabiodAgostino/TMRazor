<ui:FluentWindow x:Class="TMRazorImproved.UI.Views.Windows.SpellGridWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels"
        mc:Ignorable="d"
        Title="Spell Grid" 
        Height="Auto" Width="Auto"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual">

    <Grid x:Name="RootGrid" Margin="4">
        <ui:Card Padding="4" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}" Opacity="0.9">
            <ItemsControl ItemsSource="{Binding ActiveSpells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="{Binding Rows}" Columns="{Binding Columns}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Button Command="{Binding DataContext.CastCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                   CommandParameter="{Binding}"
                                   Padding="4" Margin="2"
                                   Width="40" Height="40"
                                   ToolTip="{Binding Name}">
                            <ui:Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Configura Slot" 
                                              Command="{Binding DataContext.ConfigureCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                              CommandParameter="{Binding}" />
                                </ContextMenu>
                            </ui:Button.ContextMenu>
                            <Grid>
                                <!-- Icona (Placeholder per ora) -->
                                <Image Source="{Binding SpellId, Converter={StaticResource SpellIconConverter}}" Stretch="Uniform" />
                                
                                <!-- Cooldown Overlay -->
                                <ui:ProgressRing Progress="{Binding CooldownProgress}" 
                                                IsIndeterminate="False"
                                                Width="32" Height="32"
                                                Visibility="{Binding IsOnCooldown, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                
                                <!-- Cooldown Text -->
                                <TextBlock Text="{Binding RemainingCooldown, StringFormat={}{0:F1}}" 
                                           FontSize="10" 
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           Visibility="{Binding IsOnCooldown, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="2" ShadowDepth="1" />
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Grid>
                        </ui:Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
