<ui:FluentWindow x:Class="TMRazorImproved.UI.Views.Windows.MapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:TMRazorImproved.UI.Views.Controls"
        xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels"
        mc:Ignorable="d"
        Title="World Map" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="World Map" Icon="{ui:SymbolIcon MyLocation24}" />

        <!-- Toolbar -->
        <ui:Card Grid.Row="1" Margin="12,4" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <ui:Button Icon="{ui:SymbolIcon ZoomIn24}" 
                           Command="{Binding ZoomInCommand}" 
                           Margin="0,0,8,0"
                           ToolTip="Zoom In"/>
                
                <ui:Button Icon="{ui:SymbolIcon ZoomOut24}" 
                           Command="{Binding ZoomOutCommand}" 
                           Margin="0,0,16,0"
                           ToolTip="Zoom Out"/>

                <ui:ToggleSwitch Content="Auto-Track Player" 
                                 IsChecked="{Binding IsTracking, Mode=TwoWay}"
                                 Margin="0,0,16,0" />

                <Separator Margin="0,0,16,0" />

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:TextBlock Text="X: " Appearance="Secondary" />
                    <ui:TextBlock Text="{Binding PlayerX}" FontWeight="SemiBold" Margin="0,0,12,0" />
                    <ui:TextBlock Text="Y: " Appearance="Secondary" />
                    <ui:TextBlock Text="{Binding PlayerY}" FontWeight="SemiBold" Margin="0,0,12,0" />
                    <ui:TextBlock Text="Map: " Appearance="Secondary" />
                    <ui:TextBlock Text="{Binding MapId}" FontWeight="SemiBold" />
                </StackPanel>
            </StackPanel>
        </ui:Card>

        <!-- Map Container -->
        <ui:Card Grid.Row="2" Margin="12" Padding="0" ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <controls:MapControl HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                    <controls:MapControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}" />
                    </controls:MapControl.LayoutTransform>
                </controls:MapControl>
            </ScrollViewer>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
