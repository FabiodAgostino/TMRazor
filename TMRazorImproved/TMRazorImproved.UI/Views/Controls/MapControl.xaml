<UserControl x:Class="TMRazorImproved.UI.Views.Controls.MapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="MapGrid" Background="#111">
        <Image x:Name="MapImage" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top" />
        <Canvas x:Name="OverlayCanvas">
            <Ellipse x:Name="PlayerMarker" Width="10" Height="10" Fill="Red" Stroke="White" StrokeThickness="1" />
        </Canvas>
    </Grid>
</UserControl>
