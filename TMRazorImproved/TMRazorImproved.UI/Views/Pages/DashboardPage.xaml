<Page x:Class="TMRazorImproved.UI.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="{loc:Loc Dashboard.Title}">

    <ScrollViewer Margin="24">
        <StackPanel>
            <ui:TextBlock Text="{loc:Loc Dashboard.Header}"
                          FontWeight="Bold"
                          FontSize="32"
                          Margin="0,0,0,8" />
            
            <ui:TextBlock Text="{loc:Loc Dashboard.Welcome}"
                          Appearance="Secondary"
                          Margin="0,0,0,24" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- System Status -->
                <ui:Card Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Top">
                    <StackPanel>
                        <ui:TextBlock Text="{loc:Loc Dashboard.SystemStatus}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <ui:InfoBar Title="{loc:Loc Dashboard.CoreEngine}" Message="v10.0.0 (NET 10)" IsOpen="True" Severity="Success" Margin="0,0,0,8" ToolTip="{loc:Loc Dashboard.CoreEngine.ToolTip}"/>
                        <ui:InfoBar Title="{loc:Loc Dashboard.Network}" Message="{loc:Loc Dashboard.Network.Connected}" IsOpen="True" Severity="Informational" Margin="0,0,0,8" ToolTip="{loc:Loc Dashboard.Network.ToolTip}"/>
                        
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{loc:Loc Dashboard.Language.ToolTip}">
                                <ui:TextBlock Text="{loc:Loc Dashboard.Language}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox Width="120" 
                                          ItemsSource="{Binding AvailableLanguages}" 
                                          SelectedItem="{Binding SelectedLanguage}" />
                            </StackPanel>

                            <ui:Button Grid.Column="1" Content="{loc:Loc Dashboard.Diagnostics}" Icon="Pulse24" HorizontalAlignment="Right" ToolTip="{loc:Loc Dashboard.Diagnostics.ToolTip}"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Ping Status -->
                <ui:Card Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Top">
                    <StackPanel>
                        <ui:TextBlock Text="Ping Status" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock Text="Current Ping:" VerticalAlignment="Center"/>
                            <ui:TextBlock Grid.Column="1" Text="{Binding CurrentPing, StringFormat='{}{0:F0} ms'}" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <ui:TextBlock Text="Min" FontSize="12" Appearance="Secondary" HorizontalAlignment="Center"/>
                                <ui:TextBlock Text="{Binding MinPing, StringFormat='{}{0:F0} ms'}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <ui:TextBlock Text="Max" FontSize="12" Appearance="Secondary" HorizontalAlignment="Center"/>
                                <ui:TextBlock Text="{Binding MaxPing, StringFormat='{}{0:F0} ms'}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <ui:TextBlock Text="Avg" FontSize="12" Appearance="Secondary" HorizontalAlignment="Center"/>
                                <ui:TextBlock Text="{Binding AvgPing, StringFormat='{}{0:F0} ms'}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <ui:Button Command="{Binding StartPingCommand}" 
                                   Content="Start Ping Test" 
                                   Icon="Pulse24"
                                   HorizontalAlignment="Stretch" 
                                   Margin="0,8,0,0"
                                   Appearance="Secondary"/>
                    </StackPanel>
                </ui:Card>

                <!-- Media & Capture -->
                <ui:Card Grid.Column="0" Grid.Row="1" Margin="0,16,8,0" VerticalAlignment="Top">
                    <StackPanel>
                        <ui:TextBlock Text="{loc:Loc Dashboard.MediaCapture}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <ui:Button Grid.Column="0" 
                                       Content="{loc:Loc Dashboard.Screenshot}" 
                                       Icon="Camera24" 
                                       Command="{Binding TakeScreenshotCommand}"
                                       Margin="0,0,4,0"
                                       HorizontalAlignment="Stretch"
                                       ToolTip="{loc:Loc Dashboard.Screenshot.ToolTip}"/>
                            
                            <ui:Button Grid.Column="1" 
                                       Command="{Binding ToggleRecordingCommand}"
                                       Margin="4,0,0,0"
                                       HorizontalAlignment="Stretch"
                                       ToolTip="{loc:Loc Dashboard.RecordVideo.ToolTip}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Content" Value="{loc:Loc Dashboard.RecordVideo}"/>
                                        <Setter Property="Icon" Value="{ui:SymbolIcon Video24}"/>
                                        <Setter Property="Appearance" Value="Secondary"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                <Setter Property="Content" Value="STOP"/>
                                                <Setter Property="Icon" Value="{ui:SymbolIcon Stop24}"/>
                                                <Setter Property="Appearance" Value="Danger"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                        </Grid>

                        <ui:TextBlock Text="{loc:Loc Dashboard.RecentCaptures}" FontSize="14" FontWeight="Medium" Margin="0,0,0,8"/>
                        
                        <ItemsControl ItemsSource="{Binding RecentScreenshots}" Margin="0,0,0,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2" BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" CornerRadius="4" ClipToBounds="True">
                                        <Image Source="{Binding}" Width="80" Height="60" Stretch="UniformToFill" ToolTip="{Binding}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ui:Button Content="{loc:Loc Dashboard.OpenGallery}" 
                                   Icon="Folder24" 
                                   Command="{Binding OpenGalleryCommand}" 
                                   Appearance="Secondary"
                                   HorizontalAlignment="Stretch"
                                   ToolTip="{loc:Loc Dashboard.OpenGallery.ToolTip}"/>
                    </StackPanel>
                </ui:Card>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
