<Page x:Class="TMRazorImproved.UI.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Dashboard">

    <Grid Margin="32">
        <StackPanel>
            <ui:TextBlock Text="Welcome to TMRazor Improved"
                          FontWeight="Bold"
                          FontSize="24"
                          Margin="0,0,0,16" />
            
            <ui:TextBlock Text="Select a category from the sidebar to begin."
                          Appearance="Secondary"
                          Margin="0,0,0,16" />

            <ui:Card Margin="0,16,0,0">
                <StackPanel>
                    <ui:TextBlock Text="Status: Initializing .NET 10 Engine..." 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />
                    <ProgressBar IsIndeterminate="True" Height="4" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </Grid>
</Page>
