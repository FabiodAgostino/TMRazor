<Page x:Class="TMRazorImproved.UI.Views.Pages.Agents.VendorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels.Agents"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="Vendor">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header e Gestione Liste -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <ui:TextBlock Text="{loc:Loc Agents.Vendor.Title}" FontSize="24" FontWeight="Bold" Margin="0,0,0,16" />
            
            <ui:Card Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <ui:TextBlock Text="{loc:Loc Agents.General.ActiveList}" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold"/>
                        <ComboBox Width="200" 
                                  ItemsSource="{Binding Lists}" 
                                  SelectedItem="{Binding SelectedList, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  VerticalAlignment="Center"/>
                        
                        <ui:Button Command="{Binding AddListCommand}" 
                                   Icon="{ui:SymbolIcon Add24}" 
                                   Margin="12,0,4,0" 
                                   ToolTip="{loc:Loc Agents.General.AddList.ToolTip}"/>
                        <ui:Button Command="{Binding CloneListCommand}" 
                                   Icon="{ui:SymbolIcon Copy24}" 
                                   Margin="0,0,4,0" 
                                   ToolTip="{loc:Loc Agents.General.CloneList.ToolTip}"/>
                        <ui:Button Command="{Binding RemoveListCommand}" 
                                   Icon="{ui:SymbolIcon Delete24}" 
                                   Appearance="Secondary" 
                                   ToolTip="{loc:Loc Agents.General.RemoveList.ToolTip}"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </StackPanel>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- BUY AGENT -->
            <TabItem Header="{loc:Loc Agents.Vendor.Buy}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ui:Card Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:Loc Agents.Vendor.BuyBag}" FontWeight="SemiBold" />
                                    <ui:TextBlock Text="{Binding BuyBagName}" Appearance="Secondary" />
                                </StackPanel>
                                <ui:Button Grid.Column="1" 
                                           Command="{Binding SetBuyBagCommand}" 
                                           Content="{loc:Loc Agents.General.SetContainer}" 
                                           Icon="{ui:SymbolIcon Target24}"
                                           ToolTip="{loc:Loc Agents.General.SetContainer.ToolTip}"/>
                            </Grid>

                            <UniformGrid Columns="2">
                                <ui:ToggleSwitch Content="{loc:Loc Agents.Vendor.BuyEnabled}" 
                                                 IsChecked="{Binding BuyEnabled, Mode=TwoWay}" 
                                                 ToolTip="{loc:Loc Agents.Vendor.BuyEnabled.ToolTip}"/>
                                <ui:ToggleSwitch Content="{loc:Loc Agents.Vendor.LogPurchases}" 
                                                 IsChecked="{Binding LogPurchases, Mode=TwoWay}" 
                                                 ToolTip="{loc:Loc Agents.Vendor.LogPurchases.ToolTip}"/>
                            </UniformGrid>
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Row="1" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4">
                                <ui:Button Content="{loc:Loc Agents.General.AddItem}" Icon="{ui:SymbolIcon Add24}" Command="{Binding AddBuyItemCommand}" Margin="0,0,8,0" ToolTip="{loc:Loc Agents.General.AddItem.ToolTip}"/>
                            </StackPanel>
                            <ListView Grid.Row="1" ItemsSource="{Binding BuyList}" BorderThickness="0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{loc:Loc Agents.General.Col.Enabled}" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate><CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" /></DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{loc:Loc Agents.General.Col.Name}" DisplayMemberBinding="{Binding Name}" Width="200" />
                                        <GridViewColumn Header="Qty" DisplayMemberBinding="{Binding Amount}" Width="60" />
                                        <GridViewColumn Header="{loc:Loc Agents.General.Col.Actions}" Width="60">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent" 
                                                               Command="{Binding DataContext.RemoveBuyItemCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                               CommandParameter="{Binding}" 
                                                               ToolTip="{loc:Loc Agents.General.Action.Remove.ToolTip}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </ui:Card>
                </Grid>
            </TabItem>

            <!-- SELL AGENT -->
            <TabItem Header="{loc:Loc Agents.Vendor.Sell}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ui:Card Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:Loc Agents.Vendor.SellBag}" FontWeight="SemiBold" />
                                    <ui:TextBlock Text="{Binding SellBagName}" Appearance="Secondary" />
                                </StackPanel>
                                <ui:Button Grid.Column="1" 
                                           Command="{Binding SetSellBagCommand}" 
                                           Content="{loc:Loc Agents.General.SetContainer}" 
                                           Icon="{ui:SymbolIcon Target24}"
                                           ToolTip="{loc:Loc Agents.General.SetContainer.ToolTip}"/>
                            </Grid>

                            <UniformGrid Columns="2">
                                <ui:ToggleSwitch Content="{loc:Loc Agents.Vendor.SellEnabled}" 
                                                 IsChecked="{Binding SellEnabled, Mode=TwoWay}" 
                                                 ToolTip="{loc:Loc Agents.Vendor.SellEnabled.ToolTip}"/>
                                <ui:ToggleSwitch Content="{loc:Loc Agents.Vendor.CompareName}" 
                                                 IsChecked="{Binding CompareName, Mode=TwoWay}" 
                                                 ToolTip="{loc:Loc Agents.Vendor.CompareName.ToolTip}"/>
                                <StackPanel Margin="0,8,0,0">
                                    <ui:TextBlock Text="{loc:Loc Agents.Vendor.MaxSell}" Appearance="Secondary" FontSize="12" />
                                    <ui:NumberBox Value="{Binding MaxSellAmount, Mode=TwoWay}" Minimum="1" Maximum="1000" />
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Row="1" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4">
                                <ui:Button Content="{loc:Loc Agents.General.AddItem}" Icon="{ui:SymbolIcon Add24}" Command="{Binding AddSellItemCommand}" Margin="0,0,8,0" ToolTip="{loc:Loc Agents.General.AddItem.ToolTip}"/>
                            </StackPanel>
                            <ListView Grid.Row="1" ItemsSource="{Binding SellList}" BorderThickness="0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{loc:Loc Agents.General.Col.Enabled}" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate><CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" /></DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="{loc:Loc Agents.General.Col.Name}" DisplayMemberBinding="{Binding Name}" Width="200" />
                                        <GridViewColumn Header="{loc:Loc Agents.General.Col.Actions}" Width="60">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent" 
                                                               Command="{Binding DataContext.RemoveSellItemCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                               CommandParameter="{Binding}" 
                                                               ToolTip="{loc:Loc Agents.General.Action.Remove.ToolTip}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </ui:Card>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Activity Log -->
        <Expander Grid.Row="2" Margin="0,12,0,0" Header="{loc:Loc Agents.General.Log}" IsExpanded="False">
            <ui:Card Padding="0" Margin="0,8,0,0">
                <ListBox ItemsSource="{Binding Logs}" Height="120" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Text="{Binding FormattedTime}" Appearance="Secondary" Margin="0,0,8,0" />
                                <ui:TextBlock Grid.Column="1" Text="{Binding Message}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ui:Card>
        </Expander>

        <!-- Status Bar -->
        <ui:InfoBar Grid.Row="3" Margin="0,12,0,0"
                   Title="{loc:Loc Agents.General.Status}" 
                   Message="{Binding StatusText}" 
                   IsOpen="True" 
                   Severity="Informational" />
    </Grid>
</Page>
