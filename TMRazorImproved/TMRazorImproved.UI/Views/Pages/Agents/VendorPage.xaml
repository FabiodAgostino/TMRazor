<Page x:Class="TMRazorImproved.UI.Views.Pages.Agents.VendorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels.Agents"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Vendor Agent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TextBlock Text="Vendor Buy &amp; Sell Agent" FontSize="24" FontWeight="Bold" Margin="0,0,0,16" Grid.Row="0" />

        <!-- Gestione Liste -->
        <ui:Card Grid.Row="0" Padding="12" Margin="0,48,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal">
                    <ui:TextBlock Text="Vendor List:" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold"/>
                    <ComboBox Width="200" 
                              ItemsSource="{Binding ViewModel.Lists}" 
                              SelectedItem="{Binding ViewModel.SelectedList, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              VerticalAlignment="Center"/>
                    
                    <ui:Button Command="{Binding ViewModel.AddListCommand}" 
                               Icon="{ui:SymbolIcon Add24}" 
                               Margin="12,0,4,0" 
                               ToolTip="Add New List"/>
                    <ui:Button Command="{Binding ViewModel.CloneListCommand}" 
                               Icon="{ui:SymbolIcon Copy24}" 
                               Margin="0,0,4,0" 
                               ToolTip="Clone Selected List"/>
                    <ui:Button Command="{Binding ViewModel.RemoveListCommand}" 
                               Icon="{ui:SymbolIcon Delete24}" 
                               Appearance="Secondary" 
                               ToolTip="Remove Selected List"/>
                </StackPanel>
            </Grid>
        </ui:Card>

        <TabControl Grid.Row="1">
            <!-- BUY TAB -->
            <TabItem Header="Buy Agent">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ui:Card Grid.Row="0" Margin="0,0,0,12">
                        <UniformGrid Columns="2">
                            <StackPanel>
                                <ui:ToggleSwitch IsChecked="{Binding ViewModel.BuyEnabled, Mode=TwoWay}" 
                                                Content="Enable Auto-Buy" />
                                <ui:TextBlock Text="Automatically buys items from vendor menus." 
                                             Appearance="Secondary" FontSize="11" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <ui:ToggleSwitch IsChecked="{Binding ViewModel.LogPurchases, Mode=TwoWay}" 
                                                Content="Log Purchases" />
                                <ui:ToggleSwitch IsChecked="{Binding ViewModel.CompareName, Mode=TwoWay}" 
                                                Content="Compare Item Name" Margin="0,4,0,0" />
                            </StackPanel>
                        </UniformGrid>
                    </ui:Card>

                    <ui:Card Grid.Row="1" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <ui:TextBlock Text="Destination Buy Bag" FontWeight="SemiBold" />
                                <ui:TextBlock Text="{Binding ViewModel.BuyBagName}" Appearance="Secondary" />
                            </StackPanel>
                            <ui:Button Grid.Column="1" Command="{Binding ViewModel.SetBuyBagCommand}" Content="Set Bag" Icon="{ui:SymbolIcon Target24}" />
                        </Grid>
                    </ui:Card>

                    <ui:Card Grid.Row="2" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4">
                                <ui:Button Content="Add Buy Item" Icon="{ui:SymbolIcon Add24}" Command="{Binding ViewModel.AddBuyItemCommand}" />
                            </StackPanel>

                            <ListView Grid.Row="1" ItemsSource="{Binding ViewModel.BuyList}" BorderThickness="0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="X" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="ID" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding FormattedGraphic}" FontFamily="Consolas" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Color" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding FormattedColor}" FontFamily="Consolas" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="150" />
                                        <GridViewColumn Header="Amount" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ui:NumberBox Value="{Binding Amount, Mode=TwoWay}" Minimum="1" Maximum="999" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Props" DisplayMemberBinding="{Binding FormattedProperties}" Width="120" />
                                        <GridViewColumn Header="Actions" Width="60">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent" 
                                                               Command="{Binding DataContext.ViewModel.RemoveBuyItemCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                               CommandParameter="{Binding}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </ui:Card>
                </Grid>
            </TabItem>

            <!-- SELL TAB -->
            <TabItem Header="Sell Agent">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ui:Card Grid.Row="0" Margin="0,0,0,12">
                        <UniformGrid Columns="2">
                            <StackPanel>
                                <ui:ToggleSwitch IsChecked="{Binding ViewModel.SellEnabled, Mode=TwoWay}" 
                                                Content="Enable Auto-Sell" />
                                <ui:TextBlock Text="Automatically sells items to vendors." 
                                             Appearance="Secondary" FontSize="11" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <ui:TextBlock Text="Max Sell Amount" Appearance="Secondary" FontSize="11" />
                                <ui:NumberBox Value="{Binding ViewModel.MaxSellAmount, Mode=TwoWay}" Minimum="1" Maximum="10000" />
                            </StackPanel>
                        </UniformGrid>
                    </ui:Card>

                    <ui:Card Grid.Row="1" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <ui:TextBlock Text="Source Sell Bag" FontWeight="SemiBold" />
                                <ui:TextBlock Text="{Binding ViewModel.SellBagName}" Appearance="Secondary" />
                            </StackPanel>
                            <ui:Button Grid.Column="1" Command="{Binding ViewModel.SetSellBagCommand}" Content="Set Bag" Icon="{ui:SymbolIcon Target24}" />
                        </Grid>
                    </ui:Card>

                    <ui:Card Grid.Row="2" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4">
                                <ui:Button Content="Add Sell Item" Icon="{ui:SymbolIcon Add24}" Command="{Binding ViewModel.AddSellItemCommand}" />
                            </StackPanel>

                            <ListView Grid.Row="1" ItemsSource="{Binding ViewModel.SellList}" BorderThickness="0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="X" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="ID" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding FormattedGraphic}" FontFamily="Consolas" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Color" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding FormattedColor}" FontFamily="Consolas" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="150" />
                                        <GridViewColumn Header="Limit" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ui:NumberBox Value="{Binding Amount, Mode=TwoWay}" Minimum="0" Maximum="999" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Props" DisplayMemberBinding="{Binding FormattedProperties}" Width="120" />
                                        <GridViewColumn Header="Actions" Width="60">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent" 
                                                               Command="{Binding DataContext.ViewModel.RemoveSellItemCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                               CommandParameter="{Binding}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </ui:Card>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Activity Log -->
        <Expander Grid.Row="2" Margin="0,12,0,0" Header="Activity Log" IsExpanded="False">
            <ui:Card Padding="0" Margin="0,8,0,0">
                <ListBox ItemsSource="{Binding ViewModel.Logs}" Height="100" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Text="{Binding FormattedTime}" Appearance="Secondary" Margin="0,0,8,0" />
                                <ui:TextBlock Grid.Column="1" Text="{Binding Message}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ui:Card>
        </Expander>

        <!-- Status Bar -->
        <ui:InfoBar Grid.Row="3" Margin="0,12,0,0"
                   Title="Status" 
                   Message="{Binding ViewModel.StatusText}" 
                   IsOpen="True" 
                   Severity="Informational" />
    </Grid>
</Page>
