<Page x:Class="TMRazorImproved.UI.Views.Pages.Agents.RestockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels.Agents"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Restock">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header e Gestione Liste -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <ui:TextBlock Text="{loc:Loc Agents.Restock.Title}" FontSize="24" FontWeight="Bold" Margin="0,0,0,16" />
            
            <ui:Card Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <ui:TextBlock Text="{loc:Loc Agents.General.ActiveList}" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold"/>
                        <ComboBox Width="200" 
                                  ItemsSource="{Binding Lists}" 
                                  SelectedItem="{Binding SelectedList, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  VerticalAlignment="Center"/>
                        
                        <ui:Button Command="{Binding AddListCommand}" 
                                   Icon="{ui:SymbolIcon Add24}" 
                                   Margin="12,0,4,0" 
                                   ToolTip="{loc:Loc Agents.General.AddList.ToolTip}"/>
                        <ui:Button Command="{Binding CloneListCommand}" 
                                   Icon="{ui:SymbolIcon Copy24}" 
                                   Margin="0,0,4,0" 
                                   ToolTip="{loc:Loc Agents.General.CloneList.ToolTip}"/>
                        <ui:Button Command="{Binding RemoveListCommand}" 
                                   Icon="{ui:SymbolIcon Delete24}" 
                                   Appearance="Secondary" 
                                   ToolTip="{loc:Loc Agents.General.RemoveList.ToolTip}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ui:Button Content="{loc:Loc Agents.Restock.RestockNow}" 
                                   Command="{Binding RestockNowCommand}" 
                                   Appearance="Primary" 
                                   Margin="0,0,8,0"
                                   ToolTip="{loc:Loc Agents.Restock.RestockNow.ToolTip}"/>
                        <ui:ToggleSwitch IsChecked="{Binding AutoStart, Mode=TwoWay}" 
                                        Content="{loc:Loc Agents.General.Autostart}" 
                                        ToolTip="{loc:Loc Agents.General.Autostart.ToolTip}"
                                        OnContent="On" OffContent="Off" />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <ui:Card Margin="0,0,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <ui:TextBlock Text="{loc:Loc Agents.Restock.Source}" FontWeight="SemiBold" />
                            <ui:TextBlock Text="{Binding SourceName}" Appearance="Secondary" />
                        </StackPanel>
                        <ui:Button Grid.Column="1" 
                                   Command="{Binding SetSourceCommand}" 
                                   Content="{loc:Loc Agents.General.SetContainer}" 
                                   Icon="{ui:SymbolIcon Target24}"
                                   ToolTip="{loc:Loc Agents.General.SetContainer.ToolTip}"/>
                    </Grid>
                </StackPanel>
            </ui:Card>
        </StackPanel>

        <!-- Lista Item -->
        <ui:Card Grid.Row="1" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4">
                    <ui:Button Content="{loc:Loc Agents.General.AddItem}" Icon="{ui:SymbolIcon Target24}" Command="{Binding AddItemCommand}" Margin="0,0,8,0" ToolTip="{loc:Loc Agents.General.AddItem.ToolTip}"/>
                    <ui:Button Content="{loc:Loc Agents.General.ClearList}" Icon="{ui:SymbolIcon Delete24}" Command="{Binding ClearListCommand}" Appearance="Secondary" ToolTip="{loc:Loc Agents.General.ClearList.ToolTip}"/>
                </StackPanel>

                <ListView Grid.Row="1" ItemsSource="{Binding LootItems}" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{loc:Loc Agents.General.Col.Enabled}" Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{loc:Loc Agents.General.Col.Graphic}" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FormattedGraphic}" FontFamily="Consolas" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{loc:Loc Agents.General.Col.Color}" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FormattedColor}" FontFamily="Consolas" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{loc:Loc Agents.General.Col.Name}" DisplayMemberBinding="{Binding Name}" Width="150" />
                            <GridViewColumn Header="{loc:Loc Agents.General.Col.Props}" DisplayMemberBinding="{Binding FormattedProperties}" Width="150" />
                            <GridViewColumn Header="{loc:Loc Agents.General.Col.Actions}" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:Button Icon="{ui:SymbolIcon Settings24}" 
                                                       Appearance="Transparent" 
                                                       Padding="4"
                                                       Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                       CommandParameter="{Binding}" 
                                                       ToolTip="{loc:Loc Agents.General.Action.Edit.ToolTip}"/>
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" 
                                                       Appearance="Transparent" 
                                                       Padding="4"
                                                       Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                       CommandParameter="{Binding}" 
                                                       ToolTip="{loc:Loc Agents.General.Action.Remove.ToolTip}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </ui:Card>

        <!-- Activity Log -->
        <Expander Grid.Row="2" Margin="0,12,0,0" Header="{loc:Loc Agents.General.Log}" IsExpanded="False">
            <ui:Card Padding="0" Margin="0,8,0,0">
                <ListBox ItemsSource="{Binding Logs}" Height="120" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Text="{Binding FormattedTime}" Appearance="Secondary" Margin="0,0,8,0" />
                                <ui:TextBlock Grid.Column="1" Text="{Binding Message}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ui:Card>
        </Expander>

        <!-- Status Bar -->
        <ui:InfoBar Grid.Row="3" Margin="0,12,0,0"
                   Title="{loc:Loc Agents.General.Status}" 
                   Message="{Binding StatusText}" 
                   IsOpen="True" 
                   Severity="Informational" />
    </Grid>
</Page>
