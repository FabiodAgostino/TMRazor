<Page x:Class="TMRazorImproved.UI.Views.Pages.Agents.BandageHealPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels.Agents"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="BandageHeal">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Configuration Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <ui:TextBlock Text="{loc:Loc Agents.BandageHeal.Title}" FontSize="24" FontWeight="Bold" Margin="0,0,0,16" />
            
            <ui:Card Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <ui:ToggleSwitch IsChecked="{Binding IsEnabled, Mode=TwoWay}" 
                                        Content="{loc:Loc Agents.General.Enabled}" 
                                        ToolTip="{loc:Loc Agents.General.Enabled.ToolTip}"
                                        OnContent="On" OffContent="Off" Margin="0,0,16,0"/>
                        <ui:ToggleSwitch IsChecked="{Binding AutoStart, Mode=TwoWay}" 
                                        Content="{loc:Loc Agents.General.Autostart}" 
                                        ToolTip="{loc:Loc Agents.General.Autostart.ToolTip}"
                                        OnContent="On" OffContent="Off" />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <ui:Card Margin="0,0,0,0">
                <StackPanel>
                    <ui:TextBlock Text="{loc:Loc Agents.BandageHeal.Target}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <UniformGrid Columns="2">
                        <RadioButton Content="{loc:Loc Agents.BandageHeal.Self}" IsChecked="{Binding TargetSelf}" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="{loc:Loc Agents.BandageHeal.Other}" IsChecked="{Binding TargetOther}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ui:TextBlock Text="{Binding CustomTargetName}" Appearance="Secondary" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ui:Button Command="{Binding SetTargetCommand}" 
                                       Icon="{ui:SymbolIcon Target24}" 
                                       Padding="4"
                                       ToolTip="{loc:Loc Agents.General.AddItem.ToolTip}"/>
                        </StackPanel>
                    </UniformGrid>

                    <Separator Margin="0,12" />

                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,0,8,8">
                            <ui:TextBlock Text="{loc:Loc Agents.General.Delay}" Appearance="Secondary" FontSize="12" />
                            <ui:NumberBox Value="{Binding Delay, Mode=TwoWay}" Minimum="100" Maximum="10000" SmallChange="50" />
                        </StackPanel>
                        <ui:ToggleSwitch Content="{loc:Loc Agents.BandageHeal.ShowHP}" 
                                         IsChecked="{Binding ShowHPOverBody}" 
                                         Margin="0,4"
                                         ToolTip="{loc:Loc Agents.BandageHeal.ShowHP.ToolTip}"/>
                    </UniformGrid>
                </StackPanel>
            </ui:Card>
        </StackPanel>

        <!-- Status Bar -->
        <ui:InfoBar Grid.Row="2" Margin="0,12,0,0"
                   Title="{loc:Loc Agents.General.Status}" 
                   Message="{Binding StatusText}" 
                   IsOpen="True" 
                   Severity="Informational" />
    </Grid>
</Page>
