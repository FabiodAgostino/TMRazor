<Page x:Class="TMRazorImproved.UI.Views.Pages.DisplayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="1000" d:DesignWidth="800"
      Title="Display &amp; Counters"
      d:DataContext="{d:DesignInstance vm:DisplayViewModel, IsDesignTimeCreatable=False}">

    <ScrollViewer Margin="32">
        <StackPanel>
            <ui:TextBlock Text="Display &amp; Counters" FontSize="28" FontWeight="Bold" Margin="0,0,0,24"/>

            <!-- TitleBar Card -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <ui:TextBlock Text="UO TitleBar" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    
                    <ui:ToggleSwitch Content="Enable TitleBar Customization" 
                                     IsChecked="{Binding TitleBarEnabled, Mode=TwoWay}"
                                     Margin="0,0,0,12"/>

                    <ui:TextBlock Text="Template Format" Appearance="Secondary" Margin="0,0,0,4"/>
                    <ui:TextBox Text="{Binding TitleBarTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                PlaceholderText="UO - {char} [HP: {hp}/{hpmax}] ..."
                                IsEnabled="{Binding TitleBarEnabled}"/>
                    
                    <ui:TextBlock Text="Tokens: {char}, {hp}, {hpmax}, {mp}, {mpmax}, {sp}, {spmax}" 
                                 FontSize="12" Appearance="Tertiary" Margin="0,4,0,0"/>
                </StackPanel>
            </ui:Card>

            <!-- Visuals Card -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <ui:TextBlock Text="{loc:Loc Options.GameVisuals}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    
                    <UniformGrid Columns="2">
                        <ui:ToggleSwitch Content="{loc:Loc Options.Visuals.ShowNames}" 
                                         IsChecked="{Binding ShowNames, Mode=TwoWay}"
                                         Margin="0,0,0,8"/>
                        
                        <ui:ToggleSwitch Content="{loc:Loc Options.Visuals.ShowHealth}" 
                                         IsChecked="{Binding ShowHealth, Mode=TwoWay}"
                                         Margin="0,0,0,8"/>
                        
                        <ui:ToggleSwitch Content="{loc:Loc Options.Visuals.HighlightTarget}" 
                                         IsChecked="{Binding HighlightTarget, Mode=TwoWay}"
                                         Margin="0,0,0,8"/>
                        
                        <ui:ToggleSwitch Content="{loc:Loc Options.Visuals.IncomingNames}" 
                                         IsChecked="{Binding IncomingNames, Mode=TwoWay}"
                                         Margin="0,0,0,8"/>

                        <ui:ToggleSwitch Content="{loc:Loc Options.Visuals.ShowIncomingDamage}" 
                                         IsChecked="{Binding ShowIncomingDamage, Mode=TwoWay}"
                                         Margin="0,0,0,8"/>
                    </UniformGrid>
                </StackPanel>
            </ui:Card>

            <!-- Counters Card -->
            <ui:Card Margin="0,0,0,16" Padding="0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock Text="Resource Counters" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ui:Button Grid.Column="1" Content="Add" Icon="{ui:SymbolIcon Add24}" Command="{Binding AddCounterCommand}"/>
                    </Grid>

                    <ListView ItemsSource="{Binding Counters}" BorderThickness="0" MaxHeight="400">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="En" Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate><CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}"/></DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Name" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate><TextBox Text="{Binding Name, Mode=TwoWay}" BorderThickness="0" Background="Transparent"/></DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Abbr" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate><TextBox Text="{Binding Abbreviation, Mode=TwoWay}" BorderThickness="0" Background="Transparent"/></DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Graphic" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate><TextBlock Text="{Binding Graphic, StringFormat=0x{0:X4}}" VerticalAlignment="Center"/></DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Actions" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:Button Icon="{ui:SymbolIcon Target24}" 
                                                           Command="{Binding DataContext.SetCounterGraphicCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"
                                                           Appearance="Transparent" Padding="4"/>
                                                <ui:Button Icon="{ui:SymbolIcon Delete24}" 
                                                           Command="{Binding DataContext.RemoveCounterCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"
                                                           Appearance="Transparent" Padding="4"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
