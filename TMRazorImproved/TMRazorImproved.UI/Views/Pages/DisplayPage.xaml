<Page x:Class="TMRazorImproved.UI.Views.Pages.DisplayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:TMRazorImproved.UI.Views.Pages"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="Display">

    <ScrollViewer Margin="32">
        <StackPanel>
            <ui:TextBlock Text="Display Settings" FontSize="28" FontWeight="Bold" Margin="0,0,0,24"/>

            <!-- Display & Tweaks Card -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <ui:TextBlock Text="Client Window" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock Text="Force Window Size" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:NumberBox Value="{Binding ForceWidth, Mode=TwoWay}" PlaceholderText="Width" Width="100" Margin="0,0,8,0" />
                            <ui:NumberBox Value="{Binding ForceHeight, Mode=TwoWay}" PlaceholderText="Height" Width="100" />
                        </StackPanel>
                    </Grid>

                    <ui:ToggleSwitch Content="Scale Items" 
                                     IsChecked="{Binding ScaleItems, Mode=TwoWay}"
                                     Margin="0,0,0,8"/>

                    <ui:ToggleSwitch Content="Always on Top" 
                                     IsChecked="{Binding AlwaysOnTop, Mode=TwoWay}"
                                     Margin="0,0,0,8"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock Text="UI Opacity" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" Minimum="0.2" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                Value="{Binding UiOpacity, Mode=TwoWay}" />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Game Visuals Card -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <ui:TextBlock Text="Game Visuals" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    
                    <UniformGrid Columns="2">
                        <ui:ToggleSwitch Content="Show Names above Mobiles" 
                                         IsChecked="{Binding ShowNames, Mode=TwoWay}"
                                         Margin="0,0,0,8"/>
                        
                        <ui:ToggleSwitch Content="Show Health above Mobiles" 
                                         IsChecked="{Binding ShowHealth, Mode=TwoWay}"
                                         Margin="0,0,0,8"/>
                        
                        <ui:ToggleSwitch Content="Highlight Current Target" 
                                         IsChecked="{Binding HighlightTarget, Mode=TwoWay}"
                                         Margin="0,0,0,8"/>
                        
                        <ui:ToggleSwitch Content="Show Incoming Names" 
                                         IsChecked="{Binding IncomingNames, Mode=TwoWay}"
                                         Margin="0,0,0,8"/>

                        <ui:ToggleSwitch Content="Show Incoming Damage" 
                                         IsChecked="{Binding ShowIncomingDamage, Mode=TwoWay}"
                                         Margin="0,0,0,8"/>
                    </UniformGrid>

                    <ui:Button Content="Toggle Target HP Overlay" 
                               Icon="{ui:SymbolIcon HeartPulse24}"
                               Command="{Binding ToggleTargetHPCommand}"
                               Margin="0,16,0,0"
                               Appearance="Primary"/>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
