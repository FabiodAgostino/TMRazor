<Page x:Class="TMRazorImproved.UI.Views.Pages.InspectorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:TMRazorImproved.UI.Views.Pages"
      xmlns:controls="clr-namespace:TMRazorImproved.UI.Views.Controls"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Inspector">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" Text="{loc:Loc Inspector.Title}" FontSize="28" FontWeight="Bold" Margin="0,0,0,16"/>

        <TabControl Grid.Row="1">
            <!-- ENTITY TAB ... (no changes here) -->
            <TabItem Header="{loc:Loc Inspector.Tab.Entity}">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <ui:Card Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <ui:TextBlock Text="{loc:Loc Inspector.Entity.BasicInfo}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                <ui:Button Content="{loc:Loc Inspector.Entity.InspectButton}" Icon="{ui:SymbolIcon Eye24}" Command="{Binding StartInspectCommand}" Appearance="Primary" HorizontalAlignment="Stretch" Margin="0,0,0,16" ToolTip="{loc:Loc Inspector.Entity.InspectButton.ToolTip}"/>
                                
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <ui:TextBlock Text="{loc:Loc Inspector.Entity.Serial}" Appearance="Secondary" Margin="0,0,0,4"/>
                                        <ui:TextBlock Text="{Binding InspectedEntity.Serial, StringFormat=0x{0:X8}}" FontSize="18" FontWeight="Bold" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Copy24}" Command="{Binding CopySerialCommand}" VerticalAlignment="Bottom" ToolTip="{loc:Loc Inspector.Entity.CopySerial.ToolTip}"/>
                                </Grid>

                                <ui:TextBlock Text="{loc:Loc Inspector.Entity.Name}" Appearance="Secondary" Margin="0,0,0,4"/>
                                <ui:TextBlock Text="{Binding InspectedEntity.Name}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                <ui:TextBlock Text="{loc:Loc Inspector.Entity.Graphic}" Appearance="Secondary" Margin="0,0,0,4"/>
                                <ui:TextBlock Text="{Binding InspectedEntity.Graphic, StringFormat=0x{0:X4}}" FontSize="16" Margin="0,0,0,12"/>

                                <ui:TextBlock Text="{loc:Loc Inspector.Entity.Hue}" Appearance="Secondary" Margin="0,0,0,4"/>
                                <ui:TextBlock Text="{Binding InspectedEntity.Hue, StringFormat=0x{0:X4}}" FontSize="16" Margin="0,0,0,12"/>

                                <ui:TextBlock Text="{loc:Loc Inspector.Entity.Position}" Appearance="Secondary" Margin="0,0,0,4"/>
                                <ui:TextBlock Margin="0,0,0,12">
                                    <Run Text="{Binding InspectedEntity.X}" FontWeight="SemiBold"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding InspectedEntity.Y}" FontWeight="SemiBold"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding InspectedEntity.Z}" FontWeight="SemiBold"/>
                                </ui:TextBlock>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <ui:TextBlock Text="{loc:Loc Inspector.Entity.Layer}" Appearance="Secondary" Margin="0,0,0,4"/>
                                        <ui:TextBlock Text="{Binding InspectedLayer}" FontSize="14" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <ui:TextBlock Text="{loc:Loc Inspector.Entity.Amount}" Appearance="Secondary" Margin="0,0,0,4"/>
                                        <ui:TextBlock Text="{Binding InspectedAmount}" FontSize="14" />
                                    </StackPanel>
                                </Grid>

                                <ui:TextBlock Text="{loc:Loc Inspector.Entity.Container}" Appearance="Secondary" Margin="0,0,0,4"/>
                                <ui:TextBlock Text="{Binding InspectedContainer}" FontSize="14" Margin="0,0,0,12"/>

                                <ui:TextBlock Text="Raw Flags" Appearance="Secondary" Margin="0,0,0,4"/>
                                <ui:TextBlock Text="{Binding InspectedRawFlags}" FontSize="14" Margin="0,0,0,12"/>
                            </StackPanel>
                        </ui:Card>

                        <!-- Item Flags card — visible only when an Item is selected -->
                        <ui:Card Padding="16" Margin="0,0,0,12">
                            <ui:Card.Style>
                                <Style TargetType="ui:Card">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsItemInspected}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Card.Style>
                            <StackPanel>
                                <ui:TextBlock Text="Item Flags" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding ItemFlags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" Margin="0,0,4,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#2ECC71"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSet}" Value="False">
                                                                <Setter Property="Background" Value="#555555"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <ui:TextBlock Text="{Binding FlagName}" FontSize="11" Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ui:Card>

                        <!-- Mobile Details card — visible only when a Mobile is selected -->
                        <ui:Card Padding="16" Margin="0,0,0,12">
                            <ui:Card.Style>
                                <Style TargetType="ui:Card">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMobileInspected}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Card.Style>
                            <StackPanel>
                                <ui:TextBlock Text="Mobile Details" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                <!-- HP bar -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Column="0" Text="HP" Appearance="Secondary" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding MobileHitsPercent, Mode=OneWay}" Maximum="100" Height="12" VerticalAlignment="Center" Foreground="#E74C3C"/>
                                    <ui:TextBlock Grid.Column="2" Text="{Binding MobileHitsText}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <!-- Mana bar -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Column="0" Text="Mana" Appearance="Secondary" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding MobileManaPercent, Mode=OneWay}" Maximum="100" Height="12" VerticalAlignment="Center" Foreground="#3498DB"/>
                                    <ui:TextBlock Grid.Column="2" Text="{Binding MobileManaText}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <!-- Stam bar -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Column="0" Text="Stam" Appearance="Secondary" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding MobileStamPercent, Mode=OneWay}" Maximum="100" Height="12" VerticalAlignment="Center" Foreground="#2ECC71"/>
                                    <ui:TextBlock Grid.Column="2" Text="{Binding MobileStamText}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Notoriety / Direction -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <ui:TextBlock Text="Notoriety" Appearance="Secondary" FontSize="11" Margin="0,0,0,2"/>
                                        <ui:TextBlock Text="{Binding MobileNotoriety}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <ui:TextBlock Text="Direction" Appearance="Secondary" FontSize="11" Margin="0,0,0,2"/>
                                        <ui:TextBlock Text="{Binding MobileDirection}" FontSize="12"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Stats line -->
                                <ui:TextBlock Text="Stats / Resists" Appearance="Secondary" FontSize="11" Margin="0,0,0,2"/>
                                <ui:TextBlock Text="{Binding MobileStats}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <!-- Mobile flags -->
                                <ui:TextBlock Text="Flags" Appearance="Secondary" FontSize="11" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding MobileFlags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" Margin="0,0,4,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#2ECC71"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSet}" Value="False">
                                                                <Setter Property="Background" Value="#555555"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <ui:TextBlock Text="{Binding FlagName}" FontSize="11" Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="8">
                            <StackPanel>
                                <ui:TextBlock Text="{loc:Loc Inspector.Entity.RecentTargets}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ListBox ItemsSource="{Binding RecentSerials}" Height="150" Background="Transparent" BorderThickness="0" FontSize="12"/>
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>

                    <ui:Card Grid.Column="1" Padding="16">
                        <DockPanel>
                            <ui:TextBlock Text="{loc:Loc Inspector.Entity.Properties}" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Top" Margin="0,0,0,16"/>
                            <ListView ItemsSource="{Binding InspectedEntity.OPL.Properties}" Background="Transparent" BorderThickness="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <ui:TextBlock Text="{Binding Text}" FontSize="13" FontWeight="Medium" TextWrapping="Wrap"/>
                                            <ui:TextBlock Text="{Binding Cliloc, StringFormat=Cliloc: {0}}" FontSize="10" Appearance="Secondary"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </ui:Card>
                </Grid>
            </TabItem>

            <!-- GUMP LIST MANAGER TAB -->
            <TabItem Header="{loc:Loc Inspector.Tab.GumpList}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ui:Card Grid.Row="0" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock Grid.Column="0" Text="{loc:Loc Inspector.GumpList.Description}" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <ui:Button Grid.Column="1" Content="{loc:Loc Inspector.GumpList.Refresh}" Icon="{ui:SymbolIcon ArrowCounterclockwise24}" Command="{Binding RefreshGumpsListCommand}" Appearance="Primary" ToolTip="{loc:Loc Inspector.GumpList.Refresh.ToolTip}"/>
                        </Grid>
                    </ui:Card>

                    <ui:Card Grid.Row="1">
                        <DataGrid ItemsSource="{Binding OpenGumps}" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  Background="Transparent" 
                                  BorderThickness="0"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc Inspector.GumpList.Column.ID}" Binding="{Binding GumpId, StringFormat=0x{0:X8}}" Width="100"/>
                                <DataGridTextColumn Header="{loc:Loc Inspector.GumpList.Column.Serial}" Binding="{Binding Serial, StringFormat=0x{0:X8}}" Width="100"/>
                                <DataGridTextColumn Header="{loc:Loc Inspector.GumpList.Column.X}" Binding="{Binding X}" Width="60"/>
                                <DataGridTextColumn Header="{loc:Loc Inspector.GumpList.Column.Y}" Binding="{Binding Y}" Width="60"/>
                                <DataGridTextColumn Header="{loc:Loc Inspector.GumpList.Column.Controls}" Binding="{Binding Controls.Count}" Width="80"/>
                                <DataGridTextColumn Header="{loc:Loc Inspector.GumpList.Column.Lines}" Binding="{Binding Strings.Count}" Width="80"/>
                                <DataGridTemplateColumn Header="{loc:Loc Inspector.GumpList.Column.Actions}" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:Button Content="{loc:Loc Inspector.GumpList.Action.Inspect}" 
                                                       Command="{Binding DataContext.InspectSpecificGumpCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                       CommandParameter="{Binding}"
                                                       ToolTip="{loc:Loc Inspector.GumpList.Action.Inspect.ToolTip}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ui:Card>
                </Grid>
            </TabItem>

            <!-- GUMP TAB ... (keeping current improvements) -->
            <TabItem Header="{loc:Loc Inspector.Tab.GumpInspector}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ui:Card Grid.Row="0" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <ui:TextBlock Text="{loc:Loc Inspector.Gump.CurrentInfo}" FontWeight="SemiBold" />
                                <ui:TextBlock Text="{Binding GumpInfo}" Appearance="Secondary" FontSize="12"/>
                            </StackPanel>
                            <ui:Button Grid.Column="1" Content="{loc:Loc Inspector.Gump.Refresh}" Icon="ArrowCounterclockwise24" Command="{Binding InspectGumpCommand}" Appearance="Primary" ToolTip="{loc:Loc Inspector.Gump.Refresh.ToolTip}"/>
                        </Grid>
                    </ui:Card>

                    <ui:Card Grid.Row="1" Padding="0">
                        <DockPanel>
                            <ui:TextBlock Text="{loc:Loc Inspector.Gump.ControlsTree}" FontSize="16" FontWeight="SemiBold" Margin="16,12" DockPanel.Dock="Top"/>
                            <ListView ItemsSource="{Binding GumpControls}" Background="Transparent" BorderThickness="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,2">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <ui:MenuItem Header="{loc:Loc Inspector.Gump.Action.CopyPython}" Icon="{ui:SymbolIcon Copy24}" 
                                                                 Command="{Binding DataContext.CopyAsPythonCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                 CommandParameter="{Binding}"/>
                                                    <ui:MenuItem Header="{loc:Loc Inspector.Gump.Action.CopyCSharp}" Icon="{ui:SymbolIcon Code24}" 
                                                                 Command="{Binding DataContext.CopyAsCSharpCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                 CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Component24" Margin="0,0,12,0" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                                <StackPanel Width="180">
                                                    <ui:TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                    <ui:TextBlock Text="{Binding Type}" FontSize="11" Appearance="Secondary"/>
                                                </StackPanel>
                                                <ui:Button Content="{loc:Loc Inspector.Gump.Action.Execute}" 
                                                           Icon="{ui:SymbolIcon Play24}"
                                                           Padding="4"
                                                           Margin="12,0,0,0"
                                                           Command="{Binding DataContext.ExecuteGumpActionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"
                                                           ToolTip="{loc:Loc Inspector.Gump.Action.Execute.ToolTip}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </ui:Card>
                </Grid>
            </TabItem>

            <!-- MAP TAB -->
            <TabItem Header="{loc:Loc Inspector.Tab.MapInspector}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <ui:Card Grid.Row="0" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <ui:TextBlock Text="{loc:Loc Inspector.Map.Title}" FontWeight="SemiBold" />
                                <ui:TextBlock Text="{Binding MapInfo}" Appearance="Secondary" FontSize="12"/>
                            </StackPanel>
                            <ui:Button Grid.Column="1" Content="{loc:Loc Inspector.Map.Refresh}" Icon="MyLocation24" Command="{Binding RefreshMapCommand}" Appearance="Primary" ToolTip="{loc:Loc Inspector.Map.Refresh.ToolTip}"/>
                        </Grid>
                    </ui:Card>

                    <ui:Card Grid.Row="1" Padding="0">
                        <controls:MapControl x:Name="WorldMap" 
                                           DataContext="{Binding Map}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                    </ui:Card>
                </Grid>
            </TabItem>

            <!-- TILE INSPECTOR TAB -->
            <TabItem Header="Tile Inspector">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Coordinate input card -->
                    <ui:Card Grid.Row="0" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <ui:TextBlock Text="Tile Coordinates" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <ui:TextBlock Text="X" Appearance="Secondary" FontSize="11" Margin="0,0,0,2"/>
                                    <ui:NumberBox Value="{Binding TileX, Mode=TwoWay}" SpinButtonPlacementMode="Compact" Minimum="0" Maximum="9999"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <ui:TextBlock Text="Y" Appearance="Secondary" FontSize="11" Margin="0,0,0,2"/>
                                    <ui:NumberBox Value="{Binding TileY, Mode=TwoWay}" SpinButtonPlacementMode="Compact" Minimum="0" Maximum="9999"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                    <ui:TextBlock Text="Map" Appearance="Secondary" FontSize="11" Margin="0,0,0,2"/>
                                    <ui:NumberBox Value="{Binding TileMapId, Mode=TwoWay}" SpinButtonPlacementMode="Compact" Minimum="0" Maximum="5"/>
                                </StackPanel>
                                <ui:Button Grid.Column="3" Content="Use Player Pos" Icon="{ui:SymbolIcon MyLocation24}" Command="{Binding FillTileCoordsFromPlayerCommand}" Appearance="Secondary" Margin="0,16,8,0"/>
                                <ui:Button Grid.Column="4" Content="Inspect" Icon="{ui:SymbolIcon Search24}" Command="{Binding InspectTileCommand}" Appearance="Primary" Margin="0,16,0,0"/>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Land tile result -->
                    <ui:Card Grid.Row="1" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <ui:TextBlock Text="Land Tile" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ui:TextBlock Text="{Binding LandTileInfo}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ui:Card>

                    <!-- Static tiles list -->
                    <ui:Card Grid.Row="2" Padding="0">
                        <DockPanel>
                            <ui:TextBlock Text="Static Tiles" FontSize="13" FontWeight="SemiBold" Margin="16,12" DockPanel.Dock="Top"/>
                            <DataGrid ItemsSource="{Binding StaticTiles}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Graphic" Binding="{Binding Graphic}" Width="90"/>
                                    <DataGridTextColumn Header="Hue"     Binding="{Binding Hue}"     Width="60"/>
                                    <DataGridTextColumn Header="Z"       Binding="{Binding Z}"       Width="50"/>
                                    <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </ui:Card>
                </Grid>
            </TabItem>

            <!-- GUMP HISTORY TAB -->
            <TabItem Header="{loc:Loc Inspector.Tab.GumpHistory}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ui:Card Grid.Row="0" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <ui:TextBlock Text="{loc:Loc Inspector.GumpHistory.Title}" FontWeight="SemiBold" />
                                <ui:TextBlock Text="Ultimi 50 eventi di risposta ai gump" Appearance="Secondary" FontSize="12"/>
                            </StackPanel>
                            <ui:Button Grid.Column="1" Content="{loc:Loc Inspector.GumpHistory.Clear}" Icon="Delete24" Command="{Binding ClearGumpHistoryCommand}" Appearance="Secondary" />
                        </Grid>
                    </ui:Card>

                    <ui:Card Grid.Row="1" Padding="0">
                        <ListBox ItemsSource="{Binding GumpResponseHistory}"
                                 Background="Transparent" BorderThickness="0"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <ui:TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" Margin="4,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ui:Card>
                </Grid>
            </TabItem>

            <!-- SCRIPT DEBUG TAB (FR-079) -->
            <TabItem Header="Script Debug">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ui:Card Grid.Row="0" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <ui:TextBlock Text="Script Debug Inspector" FontWeight="SemiBold"/>
                                <ui:TextBlock Text="Shared values and active timers from running scripts" Appearance="Secondary" FontSize="12"/>
                            </StackPanel>
                            <ui:Button Grid.Column="1" Content="Refresh" Icon="{ui:SymbolIcon ArrowCounterclockwise24}" Command="{Binding RefreshScriptDebugCommand}" Appearance="Primary"/>
                        </Grid>
                    </ui:Card>

                    <!-- Shared Script Data -->
                    <ui:Card Grid.Row="1" Padding="0" Margin="0,0,0,12">
                        <DockPanel>
                            <ui:TextBlock Text="Shared Values (Misc.SetSharedValue)" FontSize="13" FontWeight="SemiBold" Margin="16,12" DockPanel.Dock="Top"/>
                            <DataGrid ItemsSource="{Binding SharedScriptData}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Key"   Binding="{Binding Key}"       Width="180"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding ValueStr}"  Width="*"/>
                                    <DataGridTextColumn Header="Type"  Binding="{Binding TypeName}"  Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </ui:Card>

                    <!-- Active Timers -->
                    <ui:Card Grid.Row="2" Padding="0">
                        <DockPanel>
                            <ui:TextBlock Text="Active Timers (Timer.Create)" FontSize="13" FontWeight="SemiBold" Margin="16,12" DockPanel.Dock="Top"/>
                            <DataGrid ItemsSource="{Binding ActiveTimers}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name"      Binding="{Binding Name}"                                         Width="180"/>
                                    <DataGridTextColumn Header="Interval"  Binding="{Binding IntervalMs, StringFormat={}{0:F0} ms}"          Width="100"/>
                                    <DataGridTextColumn Header="Time Left" Binding="{Binding TimeLeftMs, StringFormat={}{0:F0} ms}"          Width="100"/>
                                    <DataGridTextColumn Header="Running"   Binding="{Binding IsRunning}"                                     Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </ui:Card>
                </Grid>
            </TabItem>
        </TabControl>

        <ui:InfoBar Grid.Row="2" Margin="0,12,0,0" Title="Status" Message="{Binding StatusMessage}" IsOpen="True" Severity="Informational" />
    </Grid>
</Page>
