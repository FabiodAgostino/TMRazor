<Page x:Class="TMRazorImproved.UI.Views.Pages.InspectorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:TMRazorImproved.UI.Views.Pages"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Inspector">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,24">
            <ui:TextBlock Text="{loc:Loc Inspector.Title}" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            <ui:Button Content="{loc:Loc Inspector.InspectButton}" Icon="Eye24" 
                       Command="{Binding StartInspectCommand}"
                       Appearance="Primary" HorizontalAlignment="Right" Padding="16,8"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Basic Info Card -->
            <ui:Card Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Top">
                <StackPanel>
                    <ui:TextBlock Text="{loc:Loc Inspector.BasicInfo}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    
                    <ui:TextBlock Text="Serial" Appearance="Secondary" Margin="0,0,0,4"/>
                    <ui:TextBlock Text="{Binding InspectedEntity.Serial, StringFormat=0x{0:X}}" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

                    <ui:TextBlock Text="Graphic / Body" Appearance="Secondary" Margin="0,0,0,4"/>
                    <ui:TextBlock Text="{Binding InspectedEntity.Graphic, StringFormat=0x{0:X}}" FontSize="18" Margin="0,0,0,12"/>

                    <ui:TextBlock Text="Hue" Appearance="Secondary" Margin="0,0,0,4"/>
                    <ui:TextBlock Text="{Binding InspectedEntity.Hue, StringFormat=0x{0:X}}" FontSize="18" Margin="0,0,0,12"/>

                    <ui:TextBlock Text="Position" Appearance="Secondary" Margin="0,0,0,4"/>
                    <ui:TextBlock Margin="0,0,0,12">
                        <Run Text="{Binding InspectedEntity.X}" FontWeight="SemiBold"/>
                        <Run Text=", "/>
                        <Run Text="{Binding InspectedEntity.Y}" FontWeight="SemiBold"/>
                        <Run Text=", "/>
                        <Run Text="{Binding InspectedEntity.Z}" FontWeight="SemiBold"/>
                    </ui:TextBlock>

                    <ui:TextBlock Text="{Binding StatusMessage}" 
                                  Appearance="Info" FontStyle="Italic" TextWrapping="Wrap"
                                  Margin="0,16,0,0"/>
                </StackPanel>
            </ui:Card>

            <!-- Properties Card (OPL) -->
            <ui:Card Grid.Column="1" Padding="16">
                <DockPanel>
                    <ui:TextBlock Text="{loc:Loc Inspector.Properties}" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Top" Margin="0,0,0,16"/>
                    
                    <ui:TextBlock Text="No properties found for this entity." 
                                  Visibility="{Binding InspectedEntity.Properties, Converter={StaticResource NotNullToVisibilityConverter}}"
                                  Appearance="Secondary" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,32,0,0"/>

                    <ListView ItemsSource="{Binding InspectedEntity.Properties.Properties}" 
                              Background="Transparent" BorderThickness="0"
                              Visibility="{Binding InspectedEntity.Properties, Converter={StaticResource NullToVisibilityConverter}}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <ui:TextBlock Text="{Binding Text}" FontSize="14" FontWeight="Medium" TextWrapping="Wrap"/>
                                    <ui:TextBlock Text="{Binding Cliloc, StringFormat=Cliloc: {0}}" FontSize="11" Appearance="Secondary"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </ui:Card>
        </Grid>
    </Grid>
</Page>
