<Page x:Class="TMRazorImproved.UI.Views.Pages.SoundPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:TMRazorImproved.UI.Views.Pages"
      xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Sound &amp; Music"
      d:DataContext="{d:DesignInstance vm:SoundViewModel, IsDesignTimeCreatable=False}">

    <Grid Margin="32">
        <StackPanel>
            <ui:TextBlock Text="Sound &amp; Music Manager" FontSize="28" FontWeight="Bold" Margin="0,0,0,24"/>

            <!-- Volume Control Card -->
            <ui:Card Margin="0,0,0,16" Padding="16">
                <StackPanel>
                    <ui:TextBlock Text="Client Volume" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Symbol="Speaker224" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1"
                                Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True"
                                Value="{Binding Volume, Mode=TwoWay}"
                                VerticalAlignment="Center"/>
                        <ui:TextBlock Grid.Column="2"
                                      Text="{Binding Volume, StringFormat={}{0:F0}%}"
                                      Width="45"
                                      TextAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"/>
                    </Grid>
                    <ui:InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                                Title="Controllo volume per processo"
                                Message="Modifica il volume audio del client Ultima Online in esecuzione. Il client deve essere avviato per avere effetto."/>
                </StackPanel>
            </ui:Card>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sounds -->
                <ui:Card Grid.Column="0" Margin="0,0,8,0" Padding="16">
                    <StackPanel>
                        <ui:TextBlock Text="Play Sound" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        <ui:TextBox PlaceholderText="Sound ID (dec/hex)"
                                    Text="{Binding SoundId, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,12"/>
                        <ui:Button Content="Play Sound"
                                   Icon="{ui:SymbolIcon Speaker224}"
                                   Command="{Binding PlaySoundCommand}"
                                   Appearance="Primary"
                                   HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ui:Card>

                <!-- Music -->
                <ui:Card Grid.Column="1" Margin="8,0,0,0" Padding="16">
                    <StackPanel>
                        <ui:TextBlock Text="Play Music" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        <ui:TextBox PlaceholderText="Music ID (dec/hex)"
                                    Text="{Binding MusicId, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,12"/>
                        <ui:Button Content="Play Music"
                                   Icon="{ui:SymbolIcon MusicNote224}"
                                   Command="{Binding PlayMusicCommand}"
                                   Appearance="Primary"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,0,0,8"/>
                        <ui:Button Content="Stop Music"
                                   Icon="{ui:SymbolIcon Stop24}"
                                   Command="{Binding StopMusicCommand}"
                                   Appearance="Secondary"
                                   HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ui:Card>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
