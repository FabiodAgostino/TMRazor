<Page x:Class="TMRazorImproved.UI.Views.Pages.OptionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:TMRazorImproved.UI.Views.Pages"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Options">

    <ScrollViewer Margin="32">
        <StackPanel>
            <ui:TextBlock Text="{loc:Loc Filters.Title}" FontSize="28" FontWeight="Bold" Margin="0,0,0,24"/>

            <!-- Classic Filters Card -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <ui:TextBlock Text="{loc:Loc Filters.Classic}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    
                    <ui:ToggleSwitch Content="{loc:Loc Filters.Light}" 
                                     IsChecked="{Binding FilterLight, Mode=TwoWay}"
                                     Margin="0,0,0,8"/>
                    
                    <ui:ToggleSwitch Content="{loc:Loc Filters.Weather}" 
                                     IsChecked="{Binding FilterWeather, Mode=TwoWay}"
                                     Margin="0,0,0,8"/>

                    <ui:ToggleSwitch Content="{loc:Loc Filters.Sound}" 
                                     IsChecked="{Binding FilterSound, Mode=TwoWay}"
                                     Margin="0,0,0,8"/>

                    <ui:ToggleSwitch Content="{loc:Loc Filters.Death}" 
                                     IsChecked="{Binding FilterDeath, Mode=TwoWay}"
                                     Margin="0,0,0,8"/>

                    <ui:ToggleSwitch Content="{loc:Loc Filters.Staff}" 
                                     IsChecked="{Binding FilterStaff, Mode=TwoWay}"
                                     Margin="0,0,0,8"/>
                    
                    <ui:ToggleSwitch Content="{loc:Loc Filters.Poison}" 
                                     IsChecked="{Binding FilterPoison, Mode=TwoWay}"
                                     Margin="0,0,0,8"/>

                    <ui:ToggleSwitch Content="{loc:Loc Filters.Snoop}" 
                                     IsChecked="{Binding FilterSnoop, Mode=TwoWay}"
                                     Margin="0,0,0,8"/>
                </StackPanel>
            </ui:Card>

            <!-- Tweaks & Quality of Life Card (Placeholder) -->
            <ui:Card>
                <StackPanel>
                    <ui:TextBlock Text="Tweaks &amp; QoL" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <ui:TextBlock Text="Future tweaks will be added here." Appearance="Secondary" FontStyle="Italic"/>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
