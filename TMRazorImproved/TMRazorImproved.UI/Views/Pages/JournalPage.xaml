<Page x:Class="TMRazorImproved.UI.Views.Pages.JournalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Journal"
      d:DataContext="{d:DesignInstance vm:JournalViewModel}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Journal Log" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Monitor in-game system and world messages" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Search and Actions -->
        <Grid Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <StackPanel Orientation="Horizontal">
                <ui:TextBox PlaceholderText="Filter journal..." 
                            Width="250" 
                            Icon="Search24"
                            Margin="0,0,8,0"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <ui:Button Content="Export" 
                           Icon="SaveArrowRight24" 
                           Margin="0,0,8,0"
                           Command="{Binding ExportCommand}" />
                <ui:Button Content="Clear" 
                           Icon="Delete24" 
                           Appearance="Secondary"
                           Command="{Binding ClearCommand}" />
            </StackPanel>
        </Grid>

        <!-- Journal List -->
        <ui:ListView Grid.Row="1" 
                     x:Name="JournalListView"
                     ItemsSource="{Binding Entries}"
                     SelectionMode="Extended"
                     KeyDown="JournalListView_KeyDown"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
            <ui:ListView.View>
                <GridView>
                    <GridViewColumn Header="Time" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Name" Width="150" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Message" Width="500">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ui:ListView.View>
        </ui:ListView>

        <!-- Footer Info -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Right">
            <TextBlock Text="Total entries: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="{Binding Entries.Count}" FontWeight="SemiBold" />
        </StackPanel>
    </Grid>
</Page>
