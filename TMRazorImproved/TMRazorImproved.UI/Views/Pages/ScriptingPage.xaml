<Page x:Class="TMRazorImproved.UI.Views.Pages.ScriptingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
      xmlns:vm="clr-namespace:TMRazorImproved.UI.ViewModels"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      xmlns:util="clr-namespace:TMRazorImproved.UI.Utilities"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="{loc:Loc Scripting.Title}"
      ScrollViewer.VerticalScrollBarVisibility="Disabled"
      VerticalAlignment="Stretch">

    <Grid Height="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
        <Grid Margin="16,8,16,16" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <!-- ===== TOOLBAR ===== -->
        <ui:Card Grid.Row="0" Margin="0,0,0,8" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: file operations + script name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Content="{loc:Loc Scripting.New}" Command="{Binding NewScriptCommand}"
                               Margin="0,0,4,0" ToolTip="{loc:Loc Scripting.New.ToolTip}"/>
                    <ui:Button Content="{loc:Loc Scripting.Open}"  Command="{Binding OpenScriptCommand}"
                               Margin="0,0,4,0" ToolTip="{loc:Loc Scripting.Open.ToolTip}"/>
                    <ui:Button Content="{loc:Loc Scripting.Save}" Command="{Binding SaveScriptCommand}"
                               Margin="0,0,12,0" ToolTip="{loc:Loc Scripting.Save.ToolTip}"/>

                    <Border Width="1" Background="{DynamicResource ControlBorderColorBrush}"
                            Margin="0,4,12,4"/>

                    <ui:TextBlock Text="{loc:Loc Scripting.Language}" VerticalAlignment="Center" Margin="0,0,6,0"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ComboBox Width="100" Margin="0,0,12,0"
                              ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              VerticalAlignment="Center"/>

                    <Border Width="1" Background="{DynamicResource ControlBorderColorBrush}"
                            Margin="0,4,12,4"/>

                    <ui:TextBlock Text="{loc:Loc Scripting.Script}" VerticalAlignment="Center" Margin="0,0,6,0"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:TextBox Width="200"
                                Text="{Binding ScriptName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="{loc:Loc Scripting.ScriptName.Placeholder}"
                                VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: Record / Stop Record / Run / Stop -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Content="⏺ Registra"
                               Appearance="Secondary"
                               Command="{Binding StartRecordCommand}"
                               Padding="12,6"
                               Margin="0,0,4,0"
                               ToolTip="Avvia registrazione azioni di gioco come script"
                               Visibility="{Binding IsNotRecordingScript, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <ui:Button Content="⏹ Ferma Reg."
                               Appearance="Caution"
                               Command="{Binding StopRecordCommand}"
                               Padding="12,6"
                               Margin="0,0,4,0"
                               ToolTip="Ferma la registrazione e inserisce il codice nell'editor"
                               Visibility="{Binding IsRecordingScript, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Border Width="1" Background="{DynamicResource ControlBorderColorBrush}"
                            Margin="0,4,8,4"/>

                    <ui:Button Content="{loc:Loc Scripting.Run}"
                               Appearance="Primary"
                               Command="{Binding RunScriptCommand}"
                               Padding="16,6"
                               Margin="0,0,6,0"
                               ToolTip="{loc:Loc Scripting.Run.ToolTip}"/>

                    <ui:Button Content="{loc:Loc Scripting.Stop}"
                               Appearance="Danger"
                               Command="{Binding StopScriptCommand}"
                               Padding="16,6"
                               Margin="0,0,8,0"
                               ToolTip="{loc:Loc Scripting.Stop.ToolTip}"/>

                    <Border Width="1" Background="{DynamicResource ControlBorderColorBrush}"
                            Margin="0,4,8,4"/>

                    <ui:Button Content="📖 API"
                               Appearance="Secondary"
                               Padding="12,6"
                               ToolTip="Apri il riferimento API di scripting"
                               Click="OpenApiReference_Click"/>
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- ===== EDITOR + CONSOLE PANEL ===== -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" MinHeight="120"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="1*" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- â”€â”€ Code Editor â”€â”€ -->
            <Border Grid.Row="0"
                    Background="#1E1E1E"
                    BorderBrush="{DynamicResource ControlBorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <avalonedit:TextEditor
                    x:Name="ScriptEditor"
                    ShowLineNumbers="True"
                    FontFamily="Consolas, 'Courier New', monospace"
                    FontSize="13"
                    Background="#1E1E1E"
                    Foreground="#D4D4D4"
                    LineNumbersForeground="#858585"
                    Padding="4,4,4,4"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    util:AvalonEditBehavior.BindableText="{Binding ScriptCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    util:AvalonEditBehavior.IsTextBindingActive="True"/>
            </Border>

            <!-- â”€â”€ GridSplitter â”€â”€ -->
            <GridSplitter Grid.Row="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource ControlBorderColorBrush}"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeNS"/>

            <!-- â”€â”€ Output Console â”€â”€ -->
            <Border Grid.Row="2"
                    Background="#141414"
                    BorderBrush="{DynamicResource ControlBorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#252526"
                            BorderBrush="{DynamicResource ControlBorderColorBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,4">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:TextBlock Text="{loc:Loc Scripting.Output}"
                                              FontWeight="SemiBold"
                                              FontSize="12"
                                              Foreground="#CCCCCC"
                                              VerticalAlignment="Center"/>
                                <ui:TextBlock Text="{Binding ExecutionStatus}"
                                              FontSize="11"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"
                                              FontStyle="Italic"/>
                            </StackPanel>
                            <ui:Button Content="{loc:Loc Scripting.Clear}"
                                       HorizontalAlignment="Right"
                                       Appearance="Secondary"
                                       Padding="10,2"
                                       FontSize="11"
                                       Command="{Binding ClearLogCommand}"
                                       ToolTip="{loc:Loc Scripting.Clear.ToolTip}"/>
                        </Grid>
                    </Border>

                    <!-- Log entries -->
                    <ListBox x:Name="LogListBox"
                             Grid.Row="1"
                             ItemsSource="{Binding LogEntries}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="4,2"
                             SelectionMode="Extended"
                             KeyDown="LogListBox_KeyDown"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="2,1"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ScriptLogEntry}">
                                <Grid Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Timestamp (not selectable, let clicks pass to ListBoxItem) -->
                                    <TextBlock Grid.Column="0" 
                                               FontFamily="Consolas, 'Courier New', monospace"
                                               FontSize="12"
                                               Text="{Binding FormattedTime, StringFormat='[{0}] ', Mode=OneWay}"
                                               Foreground="#858585"
                                               VerticalAlignment="Top"
                                               Margin="0,0,4,0"
                                               IsHitTestVisible="False"/>

                                    <!-- Message Text (Selectable TextBox) -->
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Text, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontFamily="Consolas, 'Courier New', monospace"
                                             FontSize="12"
                                             TextWrapping="NoWrap"
                                             VerticalAlignment="Top"
                                             Padding="0"
                                             Margin="0"
                                             IsTabStop="False"
                                             SelectionBrush="{DynamicResource SystemAccentColorBrush}"
                                             CaretBrush="Transparent">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <!-- default: normal output (light gray) -->
                                                <Setter Property="Foreground" Value="#D4D4D4"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}"
                                                                 Value="{x:Static vm:ScriptLogType.Error}">
                                                        <Setter Property="Foreground" Value="#F44747"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}"
                                                                 Value="{x:Static vm:ScriptLogType.System}">
                                                        <Setter Property="Foreground" Value="#DCDCAA"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </Grid>
    </Page>
