<Page x:Class="TMRazorImproved.UI.Views.Pages.MacrosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="{loc:Loc Macros.Title}"
      d:DataContext="{d:DesignInstance vm:MacrosViewModel, IsDesignTimeCreatable=False}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TextBlock Text="{loc:Loc Macros.Title}" FontSize="28" FontWeight="Bold" Margin="0,0,0,24" Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Macros List -->
            <ui:Card Grid.Column="0" Margin="0,0,16,0" Padding="0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock Text="{loc:Loc Macros.Available}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ui:Button Grid.Column="1" 
                                   Icon="{ui:SymbolIcon Open24}" 
                                   Command="{Binding ImportLegacyMacroCommand}" 
                                   Appearance="Transparent"
                                   ToolTip="Importa macro dal vecchio TMRazor"/>
                    </Grid>
                    
                    <StackPanel DockPanel.Dock="Bottom" Margin="16">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" 
                                        PlaceholderText="{loc:Loc Macros.NewName.Placeholder}" 
                                        Text="{Binding NewMacroName, UpdateSourceTrigger=PropertyChanged}" 
                                        Margin="0,0,8,0"/>
                            <ui:Button Grid.Column="1" 
                                       Icon="{ui:SymbolIcon Record24}" 
                                       Command="{Binding StartRecordingCommand}" 
                                       Appearance="Danger"
                                       ToolTip="{loc:Loc Macros.Record.ToolTip}"/>
                        </Grid>
                        
                        <ui:Button Content="{loc:Loc Macros.DeleteSelected}" 
                                   Icon="{ui:SymbolIcon Delete24}" 
                                   Command="{Binding DeleteCommand}"
                                   HorizontalAlignment="Stretch"
                                   Appearance="Secondary"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Macros}" 
                             SelectedItem="{Binding SelectedMacro}" 
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <ui:SymbolIcon Symbol="TextBulletListLtr24" Margin="0,0,12,0" />
                                    <ui:TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </ui:Card>

            <!-- Macro Controls and Editor -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ui:Card Grid.Row="0" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <ui:TextBlock Text="{Binding SelectedMacro, FallbackValue='Nessuna macro selezionata'}" 
                                         FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                            
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="{loc:Loc Macros.Play}" 
                                           Icon="{ui:SymbolIcon Play24}" 
                                           Command="{Binding PlayCommand}" 
                                           Appearance="Primary"
                                           Margin="0,0,8,0"
                                           Width="100"
                                           IsEnabled="{Binding IsPlaying, Converter={StaticResource InvertBooleanConverter}, FallbackValue=True}"/>
                                
                                <ui:Button Content="{loc:Loc Macros.Stop}" 
                                           Icon="{ui:SymbolIcon Stop24}" 
                                           Command="{Binding StopRecordingCommand}" 
                                           Appearance="Secondary"
                                           Margin="0,0,8,0"
                                           Width="100"/>

                                <ui:Button Content="{loc:Loc Macros.Record}" 
                                           Icon="{ui:SymbolIcon Record24}" 
                                           Command="{Binding StartRecordingCommand}" 
                                           Margin="0,0,8,0"
                                           Width="100">
                                    <ui:Button.Style>
                                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                            <Setter Property="Appearance" Value="Secondary" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                    <Setter Property="Appearance" Value="Danger" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:Button.Style>
                                </ui:Button>

                                <ui:Button Content="{loc:Loc Macros.SaveChanges}" 
                                           Icon="{ui:SymbolIcon Save24}" 
                                           Command="{Binding SaveStepsCommand}" 
                                           Appearance="Secondary"
                                           Width="150"/>
                            </StackPanel>
                        </StackPanel>

                        <ui:TextBlock Grid.Column="1" 
                                     Text="{loc:Loc Macros.Recording}" 
                                     Foreground="Red" 
                                     FontWeight="Bold"
                                     Visibility="{Binding IsRecording, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     VerticalAlignment="Top"/>
                    </Grid>
                </ui:Card>

                <ui:Card Grid.Row="1" Padding="0">
                    <DockPanel>
                        <ui:TextBlock Text="{loc:Loc Macros.Steps}" FontSize="18" FontWeight="SemiBold" Margin="16" DockPanel.Dock="Top"/>
                        
                        <ListView ItemsSource="{Binding MacroSteps}" 
                                  BorderThickness="0"
                                  Background="Transparent"
                                  d:ItemsSource="{d:DesignData}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{loc:Loc Macros.Column.Order}" Width="80">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:Button Icon="{ui:SymbolIcon ArrowUp20}" 
                                                               Appearance="Transparent" Padding="2"
                                                               Command="{Binding DataContext.MoveStepUpCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                               CommandParameter="{Binding}" />
                                                    <ui:Button Icon="{ui:SymbolIcon ArrowDown20}" 
                                                               Appearance="Transparent" Padding="2"
                                                               Command="{Binding DataContext.MoveStepDownCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                               CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{loc:Loc Macros.Column.Enabled}" Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                          VerticalAlignment="Center" 
                                                          HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{loc:Loc Macros.Column.Command}" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <ui:TextBox Text="{Binding Command, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                            BorderThickness="0" 
                                                            Background="Transparent"
                                                            FontFamily="Consolas" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{loc:Loc Macros.Column.Description}" Width="300">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <ui:TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                            BorderThickness="0" 
                                                            Background="Transparent"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{loc:Loc Macros.Column.Actions}" Width="60">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <ui:Button Icon="{ui:SymbolIcon Delete20}" 
                                                           Appearance="Transparent"
                                                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                           Command="{Binding DataContext.RemoveStepCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                           CommandParameter="{Binding}"
                                                           Padding="4"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </ui:Card>
            </Grid>
        </Grid>
    </Grid>
</Page>
