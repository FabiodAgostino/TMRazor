<ui:FluentWindow x:Class="TMRazorImproved.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:TMRazorImproved.UI"
        xmlns:pages="clr-namespace:TMRazorImproved.UI.Views.Pages"
        xmlns:agents="clr-namespace:TMRazorImproved.UI.Views.Pages.Agents"
        xmlns:loc="clr-namespace:TMRazorImproved.UI.Views"
        mc:Ignorable="d"
        Title="TMRazor Improved - .NET 10 Edition" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="AppTitleBar" Title="TMRazor Improved" Grid.Row="0" />

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           OpenPaneLength="220">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="{loc:Loc Nav.Dashboard}" TargetPageType="{x:Type pages:DashboardPage}" Icon="Home24" />
                <ui:NavigationViewItem Content="{loc:Loc Nav.Journal}"   TargetPageType="{x:Type pages:JournalPage}" Icon="ReadingList24" />
                <ui:NavigationViewItem Content="{loc:Loc Nav.General}"   TargetPageType="{x:Type pages:GeneralPage}" Icon="Settings24" />
                <ui:NavigationViewItem Content="{loc:Loc Nav.Options}"   TargetPageType="{x:Type pages:OptionsPage}" Icon="Options24" />
                <ui:NavigationViewItem Content="Display &amp; Counters" TargetPageType="{x:Type pages:DisplayPage}" Icon="DeveloperBoard24" />
                <ui:NavigationViewItem Content="{loc:Loc Nav.Skills}"    TargetPageType="{x:Type pages:SkillsPage}" Icon="Flash24" />                <ui:NavigationViewItem Content="{loc:Loc Nav.Hotkeys}"   TargetPageType="{x:Type pages:HotkeysPage}" Icon="Keyboard24" />
                <ui:NavigationViewItem Content="{loc:Loc Nav.Network}"   TargetPageType="{x:Type pages:PacketLoggerPage}" Icon="Broadcasting24">
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{loc:Loc Nav.SecureTrade}" TargetPageType="{x:Type pages:SecureTradePage}" Icon="ArrowSwap24" />
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{loc:Loc Nav.Gallery}"   TargetPageType="{x:Type pages:GalleryPage}" Icon="Collections24" />
                <ui:NavigationViewItem Content="{loc:Loc Nav.Scripting}" TargetPageType="{x:Type pages:ScriptingPage}" Icon="Code24" />
                
                <ui:NavigationViewItem Content="{loc:Loc Nav.Agents}" Icon="PersonCall24">
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Agents.AutoLoot}"     TargetPageType="{x:Type agents:AutoLootPage}"     Icon="Flash24" />
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Agents.Scavenger}"    TargetPageType="{x:Type agents:ScavengerPage}"    Icon="Hand24" />
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Agents.Organizer}"    TargetPageType="{x:Type agents:OrganizerPage}"    Icon="Layer24" />
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Agents.Restock}"      TargetPageType="{x:Type agents:RestockPage}"      Icon="ArrowRepeatAll24" />
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Agents.Dress}"        TargetPageType="{x:Type agents:DressPage}"        Icon="ShapeSubtract24" />
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Agents.BandageHeal}" TargetPageType="{x:Type agents:BandageHealPage}" Icon="HeartPulse24" />
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Agents.Targeting}"    TargetPageType="{x:Type agents:TargetingPage}"    Icon="Target24" />
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Agents.Vendor}"       TargetPageType="{x:Type agents:VendorPage}"       Icon="Money24" />
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Agents.Friends}"      TargetPageType="{x:Type agents:FriendsPage}"      Icon="PeopleCommunity24" />
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>
                
                <ui:NavigationViewItem Content="{loc:Loc Nav.Macros}"     TargetPageType="{x:Type pages:MacrosPage}" Icon="History24" />
                
                <ui:NavigationViewItem Content="{loc:Loc Nav.Tools}" Icon="Toolbox24">
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Tools.ObjectInspector}" TargetPageType="{x:Type pages:InspectorPage}" Icon="EyeShow24" />
                        <ui:NavigationViewItem Content="{loc:Loc Nav.Tools.GumpList}" TargetPageType="{x:Type pages:GumpListPage}" Icon="Layer24" />
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.ContentOverlay>
                <ui:SnackbarPresenter x:Name="SnackbarPresenter" 
                                      HorizontalAlignment="Right" 
                                      VerticalAlignment="Top" 
                                      Margin="0,20,20,0" />
            </ui:NavigationView.ContentOverlay>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>