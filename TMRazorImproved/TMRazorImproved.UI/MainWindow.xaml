<ui:FluentWindow x:Class="TMRazorImproved.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:TMRazorImproved.UI"
        xmlns:pages="clr-namespace:TMRazorImproved.UI.Views.Pages"
        mc:Ignorable="d"
        Title="TMRazor Improved - .NET 10 Edition" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="TMRazor Improved" Grid.Row="0" />

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           OpenPaneLength="220">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="General"   TargetPageType="{x:Type pages:GeneralPage}" />
                <ui:NavigationViewItem Content="Options"   TargetPageType="{x:Type pages:OptionsPage}" />
                <ui:NavigationViewItem Content="Hotkeys"   TargetPageType="{x:Type pages:HotkeysPage}" />
                <ui:NavigationViewItem Content="Network" />
                <ui:NavigationViewItem Content="Scripting" TargetPageType="{x:Type pages:ScriptingPage}" />
                <ui:NavigationViewItem Content="Agents">
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="AutoLoot" />
                        <ui:NavigationViewItem Content="Scavenger" />
                        <ui:NavigationViewItem Content="Organizer" />
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Macros" />
                <ui:NavigationViewItem Content="Tools" Icon="Toolbox24">
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="Object Inspector" TargetPageType="{x:Type pages:InspectorPage}" />
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.ContentOverlay>
                <Frame x:Name="RootFrame" />
            </ui:NavigationView.ContentOverlay>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
