<Application x:Class="TMRazorImproved.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:TMRazorImproved.UI.Views.Converters"
             xmlns:cfg="clr-namespace:TMRazorImproved.Shared.Models.Config;assembly=TMRazorImproved.Shared"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" />
                <ui:ControlsDictionary xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ObjectDataProvider x:Key="TargetPriorityEnumValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="cfg:TargetPriority" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>

            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <conv:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter"/>
            <conv:HotkeyDisplayConverter x:Key="HotkeyDisplayConverter"/>
            <conv:CaptureAppearanceConverter x:Key="CaptureAppearanceConverter"/>
            <conv:InvertBooleanConverter x:Key="InvertBooleanConverter"/>
            <conv:SpellIconConverter x:Key="SpellIconConverter"/>
            <conv:IntToBoolConverter x:Key="IntToBoolConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <!-- Common Effects -->
            <DropShadowEffect x:Key="ControlShadow" 
                              BlurRadius="15" 
                              Direction="270" 
                              RenderingBias="Quality" 
                              ShadowDepth="2" 
                              Opacity="0.4" 
                              Color="#000000" />

            <!-- Global Validation Error Template -->
            <ControlTemplate x:Key="ValidationErrorTemplate">
                <StackPanel>
                    <AdornedElementPlaceholder x:Name="placeholder" />
                    <Border Background="#FF4343" 
                            BorderBrush="#FF4343" 
                            BorderThickness="1" 
                            CornerRadius="0,0,4,4"
                            Padding="4,2"
                            MaxWidth="{Binding ElementName=placeholder, Path=ActualWidth}">
                        <TextBlock Text="{Binding [0].ErrorContent}" 
                                   Foreground="White" 
                                   FontSize="11" 
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ControlTemplate>

            <Style TargetType="{x:Type ui:TextBox}" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}" />
            </Style>
            <Style TargetType="{x:Type ui:NumberBox}" BasedOn="{StaticResource {x:Type ui:NumberBox}}">
                <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
